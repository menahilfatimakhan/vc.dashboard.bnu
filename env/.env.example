# VC Analytical Dashboard — environment variable template
#
# Copy this file to `.env` at the repo root (or `env/.env`) and fill in real local
# values. NEVER commit the filled-in file — see env/CLAUDE.md.
#
# All values below are placeholders only. Phase 1 targets dummy/seed data in a
# `dev` or `demo` environment — there is no live BNU system integration.

# Which environment this config is for: dev | demo
APP_ENV=dev

# Base URL the Next.js app is served from (used for links/redirects)
APP_URL=http://localhost:3000

# --- Database (Knex) ---------------------------------------------------------
# Variable names are kept generic (not Postgres/MySQL-specific) so the same shape
# can later target Oracle DB without renaming, per the project's Oracle-compatibility
# goal. Set DB_CLIENT to the Knex client in use for this environment.

DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vc_dashboard_dev
DB_USER=changeme
DB_PASSWORD=changeme

# --- Logging -------------------------------------------------------------
# One of: error | warn | info | debug — see error_handling/CLAUDE.md
LOG_LEVEL=info
